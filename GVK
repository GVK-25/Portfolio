<!-- ABOUT -->
<section id="about">
  <div class="sec-label"><span class="sec-label-line"></span><span class="sec-label-text">About Me</span></div>
  <h2 class="sec-h">Built for the hardest<br>thermal problems</h2>
  <div class="about-grid">
