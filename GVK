<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #080a0f;
  --bg2: #0d1017;
  --surface: #161c28;
  --surface2: #1c2436;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.13);
  --text: #f0f2f7;
  --text2: #8a93a8;
  --text3: #555f75;
  --accent: #4f9cf9;
  --accent2: #1a6ef5;
  --gold: #f5c842;
  --teal: #2dd4bf;
  --heading: 'Syne', sans-serif;
  --body: 'Inter', sans-serif;
}

html { scroll-behavior: smooth; }
body { font-family: var(--body); background: var(--bg); color: var(--text); font-size: 16px; line-height: 1.7; overflow-x: hidden; }
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--surface2); border-radius: 2px; }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.1rem 4rem;
  background: rgba(8,10,15,0.9);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
}
.nav-logo {
  font-family: var(--heading); font-weight: 800; font-size: 1.1rem;
  color: var(--text); text-decoration: none;
  display: flex; align-items: center; gap: 0.6rem;
}
.nav-dot {
  width: 7px; height: 7px; background: var(--accent); border-radius: 50%;
  animation: blink 2s infinite;
}
@keyframes blink { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.7)} }
.nav-links { display: flex; gap: 2.5rem; list-style: none; align-items: center; }
.nav-links a { font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text2); text-decoration: none; transition: color 0.2s; }
.nav-links a:hover { color: var(--accent); }
.nav-hire { padding: 0.5rem 1.4rem; background: var(--accent2); color: white !important; border-radius: 5px; transition: background 0.2s !important; }
.nav-hire:hover { background: var(--accent) !important; }

/* HERO */
#hero {
  min-height: 100vh; display: flex; flex-direction: column; justify-content: center;
  padding: 8rem 4rem 5rem; position: relative; overflow: hidden;
}
.hero-grid {
  position: absolute; inset: 0;
  background-image: linear-gradient(rgba(79,156,249,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(79,156,249,0.025) 1px, transparent 1px);
  background-size: 64px 64px; pointer-events: none;
}
.hero-glow { position: absolute; top: 15%; right: 15%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(79,156,249,0.07) 0%, transparent 65%); pointer-events: none; }
.hero-glow2 { position: absolute; bottom: 5%; left: 10%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(245,200,66,0.04) 0%, transparent 65%); pointer-events: none; }

.hero-badge {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(79,156,249,0.1); border: 1px solid rgba(79,156,249,0.25);
  border-radius: 100px; padding: 0.4rem 1rem;
  font-size: 0.75rem; letter-spacing: 0.06em; color: var(--accent);
  margin-bottom: 2.25rem; width: fit-content;
  animation: fadeUp 0.5s 0.1s both;
}
.badge-dot { width: 6px; height: 6px; background: var(--accent); border-radius: 50%; animation: blink 2s infinite; }

.hero-name {
  font-family: var(--heading); font-size: clamp(3.5rem, 7vw, 7rem);
  font-weight: 800; line-height: 0.95; letter-spacing: -0.025em;
  margin-bottom: 1.5rem;
  animation: fadeUp 0.6s 0.2s both;
}
.hero-name .outline { color: transparent; -webkit-text-stroke: 1px rgba(240,242,247,0.25); }
.hero-name .blue { color: var(--accent); }

.hero-tagline {
  font-size: 1.1rem; color: var(--text2); max-width: 640px; line-height: 1.8;
  margin-bottom: 2.5rem; font-weight: 300;
  animation: fadeUp 0.6s 0.35s both;
}
.hero-tagline strong { color: var(--text); font-weight: 500; }

.hero-stats {
  display: flex; gap: 0; flex-wrap: wrap;
  border: 1px solid var(--border); border-radius: 10px; overflow: hidden;
  width: fit-content; margin-bottom: 2.5rem;
  animation: fadeUp 0.6s 0.45s both;
}
.h-stat {
  padding: 1.1rem 1.75rem;
  border-right: 1px solid var(--border);
}
.h-stat:last-child { border-right: none; }
.h-stat-n {
  font-family: var(--heading); font-size: 1.75rem; font-weight: 800;
  color: var(--text); display: block; line-height: 1;
}
.h-stat-l { font-size: 0.68rem; letter-spacing: 0.09em; text-transform: uppercase; color: var(--text3); margin-top: 0.3rem; }

.hero-btns { display: flex; gap: 0.875rem; flex-wrap: wrap; animation: fadeUp 0.6s 0.55s both; }
.btn-p {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.85rem 1.9rem; background: var(--accent2); color: white;
  font-size: 0.85rem; font-weight: 500; letter-spacing: 0.03em;
  text-decoration: none; border-radius: 6px; transition: all 0.2s;
}
.btn-p:hover { background: var(--accent); transform: translateY(-1px); }
.btn-s {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.85rem 1.9rem; background: transparent; color: var(--text);
  font-size: 0.85rem; font-weight: 400; letter-spacing: 0.03em;
  text-decoration: none; border-radius: 6px; border: 1px solid var(--border2); transition: all 0.2s;
}
.btn-s:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-1px); }

.hero-orgs { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; margin-top: 3.5rem; animation: fadeUp 0.6s 0.65s both; }
.orgs-label { font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text3); }
.org-pill {
  display: inline-flex; align-items: center; gap: 0.4rem;
  padding: 0.3rem 0.9rem; background: var(--surface); border: 1px solid var(--border);
  border-radius: 100px; font-size: 0.78rem; color: var(--text2);
}
.org-pill.top { border-color: rgba(79,156,249,0.3); color: var(--accent); background: rgba(79,156,249,0.07); }

@keyframes fadeUp { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }

/* SECTION SHARED */
section { padding: 6rem 4rem; }
.sec-label { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.sec-label-line { width: 28px; height: 1.5px; background: var(--accent); }
.sec-label-text { font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); font-weight: 500; }
.sec-h { font-family: var(--heading); font-size: clamp(2rem, 4vw, 2.9rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 0.75rem; }
.sec-sub { font-size: 0.97rem; color: var(--text2); max-width: 550px; margin-bottom: 4rem; line-height: 1.8; }

/* ABOUT */
#about { background: var(--bg2); }
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
.about-cards { display: flex; flex-direction: column; gap: 0.875rem; }
.a-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1.4rem; transition: border-color 0.2s; }
.a-card:hover { border-color: var(--border2); }
.a-card-icon { font-size: 1.3rem; margin-bottom: 0.6rem; display: block; }
.a-card-title { font-family: var(--heading); font-size: 0.95rem; font-weight: 700; color: var(--text); margin-bottom: 0.35rem; }
.a-card-desc { font-size: 0.85rem; color: var(--text2); line-height: 1.65; }
.about-text p { color: var(--text2); font-size: 0.95rem; line-height: 1.85; margin-bottom: 1.1rem; }
.about-text p strong { color: var(--text); font-weight: 500; }
.edu-box { margin-top: 2rem; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
.edu-row { display: grid; grid-template-columns: 65px 1fr auto; gap: 1rem; padding: 0.9rem 1.1rem; border-bottom: 1px solid var(--border); align-items: center; transition: background 0.15s; }
.edu-row:last-child { border-bottom: none; }
.edu-row:hover { background: var(--surface); }
.edu-yr { font-family: var(--heading); font-size: 0.85rem; font-weight: 800; color: var(--accent); }
.edu-deg { font-size: 0.85rem; color: var(--text); font-weight: 500; }
.edu-inst { font-size: 0.72rem; color: var(--text3); margin-top: 0.1rem; }
.edu-g { font-family: var(--heading); font-size: 0.9rem; font-weight: 800; color: var(--gold); text-align: right; }

/* SKILLS */
#skills { background: var(--bg); }
.skills-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
.sk-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1.6rem; transition: all 0.2s; position: relative; overflow: hidden; }
.sk-card::before { content:''; position:absolute; top:0;left:0;right:0; height:2px; background:linear-gradient(90deg,var(--accent2),var(--teal)); opacity:0; transition:opacity 0.2s; }
.sk-card:hover { border-color: var(--border2); transform: translateY(-2px); }
.sk-card:hover::before { opacity: 1; }
.sk-head { display:flex; align-items:center; gap:0.7rem; margin-bottom:1.25rem; }
.sk-icon { width:36px;height:36px; background:rgba(79,156,249,0.1); border-radius:8px; display:flex;align-items:center;justify-content:center; font-size:1rem; }
.sk-title { font-family: var(--heading); font-size:0.88rem; font-weight:700; color:var(--text); }
.sk-tags { display:flex; flex-wrap:wrap; gap:0.45rem; }
.sk-tag { font-size:0.73rem; padding:0.25rem 0.65rem; background:rgba(255,255,255,0.04); border:1px solid var(--border); border-radius:4px; color:var(--text2); }
.sk-tag.h { background:rgba(79,156,249,0.1); border-color:rgba(79,156,249,0.25); color:var(--accent); }

/* EXPERIENCE */
#experience { background: var(--bg2); }
.tl { }
.tl-item { display:grid; grid-template-columns:190px 1fr; margin-bottom:0; position:relative; }
.tl-left { padding:2rem 2rem 2rem 0; border-right:1px solid var(--border); position:relative; }
.tl-left::after { content:''; position:absolute; right:-5px; top:2.3rem; width:9px; height:9px; border-radius:50%; background:var(--bg2); border:1px solid var(--border2); }
.tl-item.now .tl-left::after { background:var(--accent); border-color:var(--accent); box-shadow:0 0 14px rgba(79,156,249,0.55); }
.tl-date { font-size:0.76rem; color:var(--text3); line-height:1.5; }
.tl-date strong { display:block; font-size:0.68rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--accent); margin-bottom:0.2rem; font-weight:600; }
.tl-right { padding:2rem 0 2rem 2.5rem; border-bottom:1px solid var(--border); }
.tl-item:last-child .tl-right { border-bottom:none; }
.tl-co { font-size:0.7rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--text3); margin-bottom:0.35rem; }
.tl-role { font-family:var(--heading); font-size:1.25rem; font-weight:700; color:var(--text); margin-bottom:0.75rem; letter-spacing:-0.01em; }
.now-badge { display:inline-flex;align-items:center;gap:0.4rem; background:rgba(79,156,249,0.1); border:1px solid rgba(79,156,249,0.3); border-radius:100px; padding:0.18rem 0.75rem; font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--accent); margin-bottom:0.75rem; width:fit-content; }
.tl-desc { font-size:0.91rem; color:var(--text2); line-height:1.8; margin-bottom:1.1rem; }
.tl-desc strong { color:var(--text); font-weight:500; }
.tl-tags { display:flex; flex-wrap:wrap; gap:0.45rem; }
.tl-tag { font-size:0.7rem; padding:0.22rem 0.6rem; background:var(--surface); border:1px solid var(--border); border-radius:4px; color:var(--text3); }

/* PROJECTS */
#projects { background: var(--bg); }
.proj-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1.25rem; }
.pj { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:1.9rem; position:relative; overflow:hidden; transition:all 0.25s; }
.pj::after { content:''; position:absolute; bottom:0;left:0; height:2px; width:0%; background:linear-gradient(90deg,var(--accent2),var(--teal)); transition:width 0.4s; }
.pj:hover { border-color:var(--border2); transform:translateY(-3px); }
.pj:hover::after { width:100%; }
.pj.feat { border-color:rgba(79,156,249,0.22); background:linear-gradient(145deg,var(--surface),rgba(79,156,249,0.04)); }
.pj-top { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:1rem; }
.pj-domain { font-size:0.67rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--accent); padding:0.22rem 0.65rem; background:rgba(79,156,249,0.1); border-radius:4px; }
.pj-n { font-family:var(--heading); font-size:0.85rem; font-weight:800; color:var(--text3); }
.pj-title { font-family:var(--heading); font-size:1.1rem; font-weight:700; color:var(--text); margin-bottom:0.7rem; line-height:1.3; letter-spacing:-0.01em; }
.pj-desc { font-size:0.87rem; color:var(--text2); line-height:1.75; }
.pj-tools { display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:1.1rem; }
.pj-tool { font-size:0.69rem; padding:0.2rem 0.55rem; background:rgba(255,255,255,0.04); border:1px solid var(--border); border-radius:3px; color:var(--text3); }

/* CONTACT */
#contact { background:var(--bg2); display:grid; grid-template-columns:1fr 1fr; padding:0; }
.ct-left { padding:6rem 4rem; border-right:1px solid var(--border); }
.ct-right { padding:6rem 4rem; background:var(--surface); }
.ct-h { font-family:var(--heading); font-size:clamp(2rem,4vw,3rem); font-weight:800; line-height:1.1; margin-bottom:1rem; letter-spacing:-0.02em; }
.ct-h span { color:var(--accent); }
.ct-sub { font-size:0.95rem; color:var(--text2); max-width:370px; margin-bottom:1.75rem; line-height:1.8; }
.avail { display:flex; align-items:center; gap:0.75rem; padding:0.9rem 1.1rem; background:rgba(45,212,191,0.07); border:1px solid rgba(45,212,191,0.2); border-radius:8px; margin-bottom:2rem; }
.avail-dot { width:8px; height:8px; background:var(--teal); border-radius:50%; animation:blink 2s infinite; flex-shrink:0; }
.avail-t { font-size:0.84rem; color:var(--teal); font-weight:500; }
.avail-s { font-size:0.75rem; color:var(--text3); }
.ci-list { list-style:none; }
.ci-list li { display:flex; align-items:center; justify-content:space-between; padding:1rem 0; border-bottom:1px solid var(--border); }
.ci-list li:last-child { border-bottom:none; }
.ci-k { font-size:0.68rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--text3); }
.ci-v { font-size:0.9rem; color:var(--text2); text-decoration:none; transition:color 0.2s; }
.ci-v:hover { color:var(--accent); }

/* FOOTER */
footer { background:var(--bg); border-top:1px solid var(--border); padding:1.75rem 4rem; display:flex; align-items:center; justify-content:space-between; font-size:0.77rem; color:var(--text3); }
footer a { color:var(--text3); text-decoration:none; }
footer a:hover { color:var(--accent); }

/* RESPONSIVE */
@media(max-width:960px){
  nav{padding:1rem 1.5rem;}
  .nav-links{display:none;}
  section{padding:4rem 1.5rem;}
  #hero{padding:6rem 1.5rem 4rem;}
  .about-grid,.skills-grid{grid-template-columns:1fr;}
  .tl-item{grid-template-columns:1fr;}
  .tl-left{border-right:none;padding:1rem 0 0;}
  .tl-left::after{display:none;}
  .tl-right{padding:0.75rem 0 2rem 1.5rem;border-left:2px solid var(--border);}
  .proj-grid{grid-template-columns:1fr;}
  #contact{grid-template-columns:1fr;}
  .ct-left{border-right:none;padding:4rem 1.5rem 2rem;}
  .ct-right{padding:2rem 1.5rem 4rem;}
  footer{padding:1.5rem;flex-direction:column;gap:0.5rem;text-align:center;}
  .hero-stats{flex-wrap:wrap;}
  .h-stat{min-width:120px;}
}
</style>
</head>
